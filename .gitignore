# Claude Code per-machine / per-session metadata — never committed.
# Note: .claude/commands/, agents/, hooks/, settings.json ARE checked in
# (they are the project-scoped Claude scaffolding — see WORKFLOW.md).
.claude/worktrees/
.claude/handoff.md
.claude/settings.local.json
.claude/projects/
.claude/todos/

# Python build / packaging artefacts that should never be tracked.
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/

# Test runner caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editor / OS noise
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
