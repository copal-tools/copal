# CopalVX Server — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# --- PostgreSQL ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=asset_system

# --- SeaweedFS ---
SEAWEED_MASTER_URL=http://seaweedfs:9333
# S3 credentials — leave blank if you don't use S3 access
WEED_S3_ACCESS_KEY=
WEED_S3_SECRET_KEY=

# --- API ---
# The IP address clients use to reach SeaweedFS directly for uploads/downloads
PUBLIC_ACCESS_HOST=192.168.178.161

# --- Logging ---
# Set to WARNING in production to suppress INFO noise
LOG_LEVEL=INFO
